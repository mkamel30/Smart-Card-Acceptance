generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Models
model Settlement {
  id String @id @default(cuid())
  
  // Basic Info
  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])
  settlementDate DateTime
  bankName String?
  cardType String? // VISA, Mastercard, American Express
  
  // Business Fields from Documents
  serviceCategory String @default("SMART") 
  subService      String? // e.g., Fines, Maintenance, نوع الخدمة
  merchantCode    String // كود المخبز / التاجر
  merchantName    String? // اسم المخبز / التاجر
  batchNumber     String? // رقم الباتش
  approvalNumber  String? // رقم الموافقة
  cardBin         String? // أول 6 أرقام من البطاقة
  last4Digits     String? // آخر 4 أرقام من البطاقة
  customerName    String? // الاسم
  customerPhone   String? // رقم هاتف العميل
  
  // Amount Info
  totalAmount Decimal
  settledAmount Decimal
  fees Decimal
  netAmount Decimal
  
  // Reference
  referenceNumber String?
  invoiceNumber String?
  
  // Receipt
  receipt Receipt? // One-to-one relationship
  receiptImageUrl String?
  
  // Status
  status String @default("PENDING") // PENDING, APPROVED, SETTLED, REJECTED
  notes String?
  
  // Email
  emailSent Boolean @default(false)
  emailSentAt DateTime?
  emailRecipients String? // JSON array of email recipients
  
  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String
  
  @@index([settlementDate])
  @@index([status])
  @@index([bankName])
  @@index([serviceCategory])
}

model Receipt {
  id String @id @default(cuid())
  
  settlement Settlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  settlementId String @unique
  
  // Image Info
  imageUrl String // Uploaded receipt image
  uploadedAt DateTime @default(now())
  
  // OCR Data (extracted from image)
  extractedText String? // Raw OCR text
  merchantName String?
  merchantId String?
  transactionId String?
  transactionDate DateTime?
  
  // Processing
  processedAt DateTime?
  processingStatus String @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  
  @@index([settlementId])
}

model EmailSetting {
  id String @id @default(cuid())
  
  // Recipients
  toEmails String // JSON array
  ccEmails String? // JSON array
  bccEmails String? // JSON array
  
  // Email Content
  subject String @default("Card Settlement Report")
  bodyTemplate String // HTML template
  
  // SMTP Config
  smtpHost String
  smtpPort Int
  smtpUser String
  smtpPassword String // Encrypted
  fromEmail String
  
  // Settings
  autoSendOnApprove Boolean @default(false)
  includeReceiptPDF Boolean @default(true)
  includeExcel Boolean @default(false)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id String @id @default(cuid())
  
  entityType String // "Settlement", "Receipt", "Email"
  entityId String
  action String // "CREATE", "UPDATE", "DELETE", "EMAIL_SENT"
  
  oldValues String? // SQLite doesn't have Json type, using String
  newValues String? // JSON as string
  
  performedBy String
  createdAt DateTime @default(now())
  
  @@index([entityId])
  @@index([createdAt])
}

model Branch {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String?  @unique
  createdAt DateTime @default(now())
  settlements Settlement[]
  managers    User[]   @relation("UserBranches")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  role      String   @default("BRANCH_MANAGER") // ADMIN, BRANCH_MANAGER
  
  // Branches this user can manage (only for BRANCH_MANAGER role)
  branches  Branch[] @relation("UserBranches")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
